APP_NAME="PS Company Chatbot"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Europe/Rome
APP_URL=http://chatbot.test

# Locale
APP_LOCALE=it
APP_FALLBACK_LOCALE=en

# Logging
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# Database
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=pscompany_chatbot
DB_USERNAME=root
DB_PASSWORD=

# Cache & Session
CACHE_STORE=file
SESSION_DRIVER=file
SESSION_LIFETIME=120
QUEUE_CONNECTION=database

# Mail
MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@pscompany.cloud"
MAIL_FROM_NAME="${APP_NAME}"

# ================================================
# CONFIGURAZIONI CUSTOM
# ================================================

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_DEFAULT_MODEL=gpt-4o-mini

# n8n
N8N_WEBHOOK_URL=https://n8n.pscompany.cloud
N8N_INTERNAL_KEY=your-secret-internal-key

# Domini
ADMIN_DOMAIN=app.pscompany.cloud
API_DOMAIN=api.pscompany.cloud
CDN_DOMAIN=cdn.pscompany.cloud

# WhatsApp Business API (opzionale)
WHATSAPP_VERIFY_TOKEN=your-whatsapp-verify-token

# Limiti default
DEFAULT_MONTHLY_MESSAGE_LIMIT=1000
DEFAULT_TRIAL_DAYS=14
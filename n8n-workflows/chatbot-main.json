{
  "name": "PS Company - Chatbot Main",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "chatbot/message",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "webhook",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "position": [250, 300],
      "webhookId": "chatbot-msg"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.LARAVEL_API_URL }}/api/internal/tenant/validate",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [{ "name": "X-Internal-Key", "value": "={{ $env.N8N_INTERNAL_KEY }}" }]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [{ "name": "api_key", "value": "={{ $json.body.tenant_api_key }}" }]
        }
      },
      "id": "validate-tenant",
      "name": "Validate Tenant",
      "type": "n8n-nodes-base.httpRequest",
      "position": [450, 300]
    },
    {
      "parameters": {
        "conditions": { "boolean": [{ "value1": "={{ $json.success }}", "value2": true }] }
      },
      "id": "check-tenant",
      "name": "Tenant Valid?",
      "type": "n8n-nodes-base.if",
      "position": [650, 300]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({ success: false, error: 'Invalid API key' }) }}",
        "options": { "responseCode": 401 }
      },
      "id": "error-response",
      "name": "Error Response",
      "type": "n8n-nodes-base.respondToWebhook",
      "position": [850, 200]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.LARAVEL_API_URL }}/api/internal/conversation/context",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [{ "name": "X-Internal-Key", "value": "={{ $env.N8N_INTERNAL_KEY }}" }]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "tenant_id", "value": "={{ $('Validate Tenant').item.json.tenant.id }}" },
            { "name": "session_id", "value": "={{ $('Webhook').item.json.body.session_id }}" },
            { "name": "channel", "value": "={{ $('Webhook').item.json.body.channel || 'web' }}" },
            { "name": "visitor_info", "value": "={{ JSON.stringify($('Webhook').item.json.body.visitor_info || {}) }}" }
          ]
        }
      },
      "id": "load-context",
      "name": "Load Context",
      "type": "n8n-nodes-base.httpRequest",
      "position": [850, 400]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.LARAVEL_API_URL }}/api/internal/rag/search",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [{ "name": "X-Internal-Key", "value": "={{ $env.N8N_INTERNAL_KEY }}" }]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "tenant_id", "value": "={{ $('Validate Tenant').item.json.tenant.id }}" },
            { "name": "query", "value": "={{ $('Webhook').item.json.body.message }}" },
            { "name": "limit", "value": "5" }
          ]
        }
      },
      "id": "rag-search",
      "name": "RAG Search",
      "type": "n8n-nodes-base.httpRequest",
      "position": [1050, 400]
    },
    {
      "parameters": {
        "jsCode": "const tenant = $('Validate Tenant').item.json.tenant;\nconst settings = $('Validate Tenant').item.json.bot_settings;\nconst context = $('Load Context').item.json;\nconst ragChunks = $('RAG Search').item.json.chunks || [];\nconst userMsg = $('Webhook').item.json.body.message;\n\nlet kb = '';\nif (ragChunks.length > 0) {\n  kb = '\\n\\n--- KNOWLEDGE BASE ---\\n';\n  ragChunks.forEach((c, i) => { kb += `[${i+1}] ${c.content}\\n\\n`; });\n  kb += '--- END ---\\n';\n}\n\nconst systemPrompt = `${settings.system_prompt}${kb}\\n\\nSe non trovi risposta: ${settings.fallback_message}\\nObiettivo: ${settings.lead_goal}`;\n\nconst messages = [\n  { role: 'system', content: systemPrompt },\n  ...(context.messages || []),\n  { role: 'user', content: userMsg }\n];\n\nreturn {\n  model: settings.openai_model,\n  temperature: settings.temperature,\n  max_tokens: settings.max_tokens,\n  messages,\n  tenant_id: tenant.id,\n  conversation_id: context.conversation_id,\n  rag_ids: ragChunks.map(c => c.id)\n};"
      },
      "id": "build-prompt",
      "name": "Build Prompt",
      "type": "n8n-nodes-base.code",
      "position": [1250, 400]
    },
    {
      "parameters": {
        "resource": "chat",
        "model": "={{ $json.model }}",
        "messages": { "values": [] },
        "options": { "maxTokens": "={{ $json.max_tokens }}", "temperature": "={{ $json.temperature }}" }
      },
      "id": "openai",
      "name": "OpenAI",
      "type": "@n8n/n8n-nodes-langchain.lmChatOpenAi",
      "position": [1450, 400]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.LARAVEL_API_URL }}/api/internal/message/save",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [{ "name": "X-Internal-Key", "value": "={{ $env.N8N_INTERNAL_KEY }}" }]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "conversation_id", "value": "={{ $('Build Prompt').item.json.conversation_id }}" },
            { "name": "user_message", "value": "={{ $('Webhook').item.json.body.message }}" },
            { "name": "assistant_message", "value": "={{ $json.message.content }}" },
            { "name": "tokens_used", "value": "={{ $json.usage?.total_tokens || 0 }}" },
            { "name": "model_used", "value": "={{ $('Build Prompt').item.json.model }}" },
            { "name": "rag_chunk_ids", "value": "={{ JSON.stringify($('Build Prompt').item.json.rag_ids) }}" }
          ]
        }
      },
      "id": "save-msg",
      "name": "Save Messages",
      "type": "n8n-nodes-base.httpRequest",
      "position": [1650, 400]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({ success: true, response: $('OpenAI').item.json.message.content, conversation_id: $('Build Prompt').item.json.conversation_id }) }}"
      },
      "id": "success-response",
      "name": "Success Response",
      "type": "n8n-nodes-base.respondToWebhook",
      "position": [1850, 400]
    }
  ],
  "connections": {
    "Webhook": { "main": [[{ "node": "Validate Tenant", "type": "main", "index": 0 }]] },
    "Validate Tenant": { "main": [[{ "node": "Tenant Valid?", "type": "main", "index": 0 }]] },
    "Tenant Valid?": { "main": [[{ "node": "Error Response", "type": "main", "index": 0 }], [{ "node": "Load Context", "type": "main", "index": 0 }]] },
    "Load Context": { "main": [[{ "node": "RAG Search", "type": "main", "index": 0 }]] },
    "RAG Search": { "main": [[{ "node": "Build Prompt", "type": "main", "index": 0 }]] },
    "Build Prompt": { "main": [[{ "node": "OpenAI", "type": "main", "index": 0 }]] },
    "OpenAI": { "main": [[{ "node": "Save Messages", "type": "main", "index": 0 }]] },
    "Save Messages": { "main": [[{ "node": "Success Response", "type": "main", "index": 0 }]] }
  },
  "settings": { "executionOrder": "v1" }
}
